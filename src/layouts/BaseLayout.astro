---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Robert Otieno | Enterprise Identity, Security & IT Operations Architect',
	description = 'Enterprise Identity, Security & IT Operations Architect focused on privacy-engineered, automation-driven trust infrastructure.',
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const basePath = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const normalize = (value: string) => value.replace(/\/+$/, '') || '/';
const currentPath = normalize(Astro.url.pathname);

const homeHref = basePath;
const portfolioHref = `${basePath}portfolio/`;
const aboutHref = `${basePath}about/`;
const projectsHref = `${basePath}projects/`;

const isHome = currentPath === normalize(homeHref);
const isPortfolio = currentPath === normalize(portfolioHref);
const isAbout = currentPath === normalize(aboutHref);
const isProjects = currentPath === normalize(projectsHref);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav class="container nav">
				<a href={homeHref} aria-current={isHome ? 'page' : undefined}>Home</a>
				<a href={portfolioHref} aria-current={isPortfolio ? 'page' : undefined}>Portfolio</a>
				<a href={aboutHref} aria-current={isAbout ? 'page' : undefined}>About</a>
				<a href={projectsHref} aria-current={isProjects ? 'page' : undefined}>Projects</a>
			</nav>
		</header>
		<main class="container content">
			<slot />
		</main>
		<footer class="container footer">
			<p>Robert Otieno · Enterprise Identity, Security & IT Operations Architect</p>
		</footer>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--bg: #ffffff;
		--text: #1f2937;
		--muted: #4b5563;
		--accent: #1e3a8a;
		--accent-soft: #e7edff;
		--border: #e5e7eb;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: #fafbfc;
		color: var(--text);
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', Arial, sans-serif;
		line-height: 1.65;
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	header {
		border-bottom: 1px solid var(--border);
		background: #fff;
	}

	.container {
		max-width: min(900px, 100% - 2rem);
		margin: 0 auto;
		padding: 0 clamp(1rem, 3vw, 2rem);
	}

	.nav {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25rem;
		padding-top: 1.1rem;
		padding-bottom: 1.1rem;
	}

	.nav a {
		padding: 0.4rem 0.6rem;
		border-radius: 0.45rem;
		border: 1px solid transparent;
	}

	.nav a[aria-current='page'] {
		font-weight: 600;
		background: var(--accent-soft);
		border-color: #c7d2fe;
	}

	.content {
		padding-top: clamp(2rem, 5vw, 4rem);
		padding-bottom: clamp(2rem, 4vw, 3.5rem);
	}

	.footer {
		padding-top: 1.25rem;
		padding-bottom: 2.25rem;
		border-top: 1px solid var(--border);
	}

	.footer p {
		margin: 0;
		font-size: 0.95rem;
	}

	h1,
	h2,
	h3 {
		line-height: 1.2;
		margin-top: 0;
		color: #111827;
	}

	h1 {
		font-size: clamp(2rem, 4vw, 2.7rem);
		margin-bottom: 0.5rem;
	}

	h2 {
		font-size: clamp(1.2rem, 3.5vw, 1.4rem);
		margin-bottom: 0.75rem;
	}

	h3 {
		font-size: 1.1rem;
		margin-bottom: 0.6rem;
	}

	section {
		margin-top: clamp(2rem, 5vw, 3.25rem);
	}

	p {
		margin-top: 0;
		margin-bottom: 1rem;
		color: var(--muted);
	}

	ul {
		margin: 0;
		padding-left: 1.25rem;
	}

	li + li {
		margin-top: 0.4rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
	}

	.card {
		padding: 1.1rem;
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		background: #fff;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 0.6rem;
	}

	.lead {
		font-size: 1.1rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 1.35fr 1fr;
		gap: 1.5rem;
		align-items: center;
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--border);
	}

	.hero-art {
		border: 1px solid var(--border);
		border-radius: 0.7rem;
		padding: 0.75rem;
		background: #f9fafb;
	}

	.badges {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}

	.badges span {
		font-size: 0.87rem;
		padding: 0.28rem 0.55rem;
		border-radius: 999px;
		border: 1px solid #dbe4ff;
		background: #f8faff;
		color: #22396f;
	}

	.cta-row {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		margin-top: 0.9rem;
	}

	.cta {
		display: inline-block;
		padding: 0.5rem 0.8rem;
		border: 1px solid #c7d2fe;
		border-radius: 0.45rem;
		background: #f8faff;
		font-weight: 600;
	}

	@media (max-width: 780px) {
		.hero {
			grid-template-columns: 1fr;
		}
	}
</style>