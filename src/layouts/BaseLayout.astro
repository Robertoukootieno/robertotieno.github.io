---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Robert Otieno | Enterprise Identity, Security & IT Operations Architect',
	description = 'Enterprise Identity, Security & IT Operations Architect focused on privacy-engineered, automation-driven trust infrastructure.',
} = Astro.props;

const baseUrl = import.meta.env.BASE_URL;
const normalize = (value: string) => value.replace(/\/+$/, '') || '/';
const currentPath = normalize(Astro.url.pathname);

const homeHref = baseUrl;
const portfolioHref = `${baseUrl}portfolio/`;
const aboutHref = `${baseUrl}about/`;
const projectsHref = `${baseUrl}projects/`;

const isHome = currentPath === normalize(homeHref);
const isPortfolio = currentPath === normalize(portfolioHref);
const isAbout = currentPath === normalize(aboutHref);
const isProjects = currentPath === normalize(projectsHref);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<header>
			<nav class="container nav">
				<a href={homeHref} aria-current={isHome ? 'page' : undefined}>Home</a>
				<a href={portfolioHref} aria-current={isPortfolio ? 'page' : undefined}>Portfolio</a>
				<a href={aboutHref} aria-current={isAbout ? 'page' : undefined}>About</a>
				<a href={projectsHref} aria-current={isProjects ? 'page' : undefined}>Projects</a>
			</nav>
		</header>
		<main class="container content">
			<slot />
		</main>
	</body>
</html>

<style>
	:root {
		color-scheme: light;
		--bg: #ffffff;
		--text: #1f2937;
		--muted: #4b5563;
		--accent: #1e3a8a;
		--border: #e5e7eb;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		background: var(--bg);
		color: var(--text);
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Helvetica Neue', Arial, sans-serif;
		line-height: 1.65;
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	header {
		border-bottom: 1px solid var(--border);
	}

	.container {
		max-width: 860px;
		margin: 0 auto;
		padding: 0 1.5rem;
	}

	.nav {
		display: flex;
		gap: 1.25rem;
		padding-top: 1.1rem;
		padding-bottom: 1.1rem;
	}

	.nav a[aria-current='page'] {
		font-weight: 600;
	}

	.content {
		padding-top: 3.5rem;
		padding-bottom: 5rem;
	}

	h1,
	h2,
	h3 {
		line-height: 1.2;
		margin-top: 0;
		color: #111827;
	}

	h1 {
		font-size: clamp(2rem, 4vw, 2.7rem);
		margin-bottom: 0.5rem;
	}

	h2 {
		font-size: 1.4rem;
		margin-bottom: 0.75rem;
	}

	section {
		margin-top: 3.25rem;
	}

	p {
		margin-top: 0;
		margin-bottom: 1rem;
		color: var(--muted);
	}

	ul {
		margin: 0;
		padding-left: 1.25rem;
	}

	li + li {
		margin-top: 0.4rem;
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
	}

	.card {
		padding: 1.1rem;
		border: 1px solid var(--border);
		border-radius: 0.5rem;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.9rem;
		font-weight: 600;
		margin-bottom: 0.6rem;
	}

	.lead {
		font-size: 1.1rem;
	}
</style>