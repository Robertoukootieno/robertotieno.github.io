<script is:inline>
	const filterButtons = Array.from(document.querySelectorAll('.filter-btn'));
	const workCards = Array.from(document.querySelectorAll('.work-card'));

	filterButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const filter = button.dataset.filter || 'all';
			filterButtons.forEach((item) => item.classList.remove('is-active'));
			button.classList.add('is-active');

			workCards.forEach((card) => {
				const tags = card.getAttribute('data-tags') || '';
				const visible = filter === 'all' || tags.includes(filter);
				card.classList.toggle('is-hidden', !visible);
			});
		});
	});

	const modal = document.getElementById('case-modal');
	const modalTitle = document.getElementById('modal-title');
	const modalProblem = document.getElementById('modal-problem');
	const modalPoints = document.getElementById('modal-points');

	const caseStudies = {
		employment: {
			title: 'Decentralized Employment Verification System',
			problem: 'Built a privacy-preserving SSI employment verification model for multi-party enterprise workflows.',
			points: [
				'SSI platform integration with EBSI and walt.id',
				'Credential lifecycle: issuance, selective disclosure, verification',
				'Microservice boundaries for issuer, holder, and verifier domains',
				'Governance model for compliance and operational scalability',
			],
		},
		iam: {
			title: 'Corporate IAM Modernization',
			problem: 'Redesigned IAM lifecycle patterns for better access governance and reduced provisioning friction.',
			points: [
				'RBAC model rationalization and JML alignment',
				'Automation of access provisioning workflows',
				'Integration strategy across enterprise SaaS applications',
				'Improved audit traceability and governance consistency',
			],
		},
		privacy: {
			title: 'Privacy Engineering Initiatives',
			problem: 'Introduced privacy-by-design controls in enterprise identity and data handling workflows.',
			points: [
				'DPIA-supported privacy risk assessments',
				'Data minimization and retention control patterns',
				'ZKP and differential privacy feasibility analysis',
				'Risk-informed alignment with governance controls',
			],
		},
		itops: {
			title: 'Enterprise IT & Hybrid Collaboration Support',
			problem: 'Stabilized hybrid enterprise operations with governance-aligned IT and AV support models.',
			points: [
				'Cross-platform lifecycle standardization',
				'Operational runbooks for hybrid room technologies',
				'Identity-aware endpoint governance alignment',
				'Performance and service reliability improvements',
			],
		},
	};

	const openButtons = document.querySelectorAll('.work-btn');
	openButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const key = button.getAttribute('data-case');
			if (!key || !caseStudies[key]) return;

			const detail = caseStudies[key];
			if (!modal || !modalTitle || !modalProblem || !modalPoints) return;

			modalTitle.textContent = detail.title;
			modalProblem.textContent = detail.problem;
			modalPoints.innerHTML = detail.points.map((point) => `<li>${point}</li>`).join('');

			modal.classList.add('is-open');
			modal.setAttribute('aria-hidden', 'false');
		});
	});

	if (modal) {
		modal.addEventListener('click', (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			if (target.dataset.close !== 'true') return;

			modal.classList.remove('is-open');
			modal.setAttribute('aria-hidden', 'true');
		});
	}
</script>
